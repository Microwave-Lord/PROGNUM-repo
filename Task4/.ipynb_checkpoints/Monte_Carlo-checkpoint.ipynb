    "import numpy as np\n",
    "fun = input(\"f(x) = \")\n",
    "a = float(input(\"lower bound?\"))\n",
    "b = float(input(\"upper bound\"))\n",
    "n = int(input(\"number of points? (must be an integer)\"))\n",
    "x = np.random.uniform(a, b, n)\n",
    "y = np.array(eval(fun))\n",
    "\n",
    "monte_carlo = ((b-a)/n)*np.sum(y)\n",
    "print(monte_carlo)"
   ]
